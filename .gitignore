# ============================================================
# Sensitive or temporary files that must not be published
# ============================================================
student_anonymization_map.csv
data/**/student_anonymization_map.csv

# Raw compressed archives should not be committed to GitHub.
# Extract anonymized .txt files into data/ and data/students/ instead.
data/raw/*
!data/raw/.gitkeep
*.rar
*.zip
*.7z
*.tar
*.tar.gz

# Logs
*.log
