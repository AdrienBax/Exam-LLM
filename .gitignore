# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# Generated outputs
# ============================================================
outputs/*
